 ---
// Optional props you can pass to control page-specific things
const { title = "My Site", description = "", canonical = "" } = Astro.props;
import NavClient from '../components/Navclient.jsx';
import { FaFacebookF, FaInstagram } from "react-icons/fa";

const links = [
  { name: "Home", href: "/" },
  { name: "About", href: "/about" },
  { name: "Our Work", href: "/ourwork" },
  { name: "Contact", href: "/contact" },
];
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/logo_color.png" sizes="any">
    <link rel="stylesheet" href="../styles/global.css" />
    <link rel="canonical" href={canonical} />
    <slot name="head" />
    <meta property="og:title" content="Emerald Screen Printing | Custom Apparel & Merchandise">
    <meta property="og:description" content="Custom t-shirts, apparel, and promotional products with high-quality printing.">
    <meta property="og:image" content="https://emeraldscreenprinting.com/logo_color.png">
    <meta property="og:url" content="https://emeraldscreenprinting.com">
    <meta property="og:type" content="website">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Emerald Screen Printing | Custom Apparel & Merchandise">
    <meta name="twitter:description" content="Custom t-shirts, apparel, and promotional products with high-quality printing.">
    <meta name="twitter:image" content="https://emeraldscreenprinting.com/logo_color.png">
  </head>
  <body class="min-h-screen flex flex-col bg-emerald-50 text-gray-800">
    <!-- Navbar  -->
    <header class="sr-only">
      <nav class="">
        <a href="/" class="text-xl font-bold text-emerald-700">Emerald</a>
        <ul class="flex space-x-6">
          <li><a href="/" class="hover:text-emerald-500">Home</a></li>
          <li><a href="/about" class="hover:text-emerald-500">About</a></li>
          <li><a href="/ourwork" class="hover:text-emerald-500">Our Work</a></li>
          <li><a href="/contact" class="hover:text-emerald-500">Contact</a></li>
        </ul>
      </nav>
    </header>
    <NavClient client:load links={links} />




    <!-- Page content -->
    <main class="flex-1 bg-emerald-50">
      <slot />  <!-- This is where each page’s content will go -->
    </main>

    <!-- Footer -->
    <footer class="bg-emerald-700 text-white text-sm">
      <div class="container mx-auto px-4 py-6 flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
        <div class="flex flex-col items-center md:items-start">
          <p>&copy; 2025 Emerald Screen Printing & Embroidery. All rights reserved.</p>
          <p class="text-xs text-gray-200 mt-1">
            Powered by{" "}
            <a 
              href="https://socialcirclect.com" 
              target="_blank" 
              rel="noopener noreferrer" 
              class="underline hover:text-emerald-300 transition"
            >
              Social Circle
            </a>
          </p>
        </div>
        
        <div class="flex space-x-4 text-lg">
          <a 
            href="https://www.facebook.com/emeraldscreenprintingandembroidery" 
            target="_blank" 
            rel="noopener noreferrer" 
            aria-label="Facebook" 
            class="hover:text-emerald-300 transition"
          >
            <FaFacebookF />
          </a>
          <a 
            href="https://www.instagram.com/emeraldscreenprintingct/" 
            aria-label="Instagram" 
            target="_blank" 
            rel="noopener noreferrer" 
            class="hover:text-emerald-300 transition"
          >
            <FaInstagram />
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>
