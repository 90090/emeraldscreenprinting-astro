---
import '../styles/global.css'
import Layout from '../layouts/Layout.astro';
import ClientMarquee from '../components/ClientMarquee.jsx';
import Testimonials from '../components/Testimonials.jsx';
import HomeBanner from '../components/HomeBanner.jsx';
import ApparelShowcase from '../components/ApparelShowcase.jsx';

const bannerImages = [
  { src: "banner/shoppic1.webp", alt: "Our Equipment", slogan: "Elevate Your Brand with Emerald" },
  { 
    group: [
      { src: "banner/leftbanner.webp", alt: "Jeff making shirts" },
      { src: "banner/middlebanner.webp", alt: "Jeff putting ink on shirt" },
      { src: "banner/rightbanner.webp", alt: "Jeff distributing the ink" },
    ],
    slogan: "Wear Your Vision with Emerald"
  },
  { src: "banner/shoppic2.webp", alt: "Happy Clients", slogan: "Screenprinting that Sparks" },
  { src: "banner/shoppic3.webp", alt: "Photos of The Shop", slogan: "Stand Out with Emerald Screenprinting" },
  { src: "banner/shoppic4.webp", alt: "A machine putting ink down", slogan: "Screen Printing That Colors Your Imagination" },
];

const slogans = [
    "Elevate Your Brand with Emerald",
    "Wear Your Vision with Emerald",
    "Screenprinting that Sparks",
    "Stand Out with Emerald Screenprinting",
    "Screen Printing That Colors Your Imagination",
];

const showcase = [
  { img: "customers/dynamictree2.webp", alt:"Dynamic Tree Service", caption: "Dynamic Tree Service" },
  { img: "customers/allinone2.webp", alt:"All In One Powerwashing", caption: "All In One Powerwashing" },
  { img: "customers/dynamictrees.webp", alt:"Dynamic Tree Service", caption: "Dynamic Tree Service" },
  { img: "customers/VSsons.webp", caption: "VS Sons" },
  { img: "customers/ajplandscaping.webp", alt:"AJP Landscaping", caption: "AJP Landscaping" },
  { img: "customers/guitar.webp", alt:"Sweet Magic", caption: "Sweet Magic" },
  { img: "customers/ges.webp", alt:"Green Earth Solutions", caption: "Green Earth Solutions" },
  { img: "customers/fish.webp", caption: "Premium Fencing and Masonry" },
  { img: "customers/farmington.webp", caption: "Farmington Football" },
  { img: "customers/Adell.webp", caption: "Adell Landscaping" },
];

const clientLogos = [
  { name: "Adell Landscaping", src: "logos/adell.webp" },
  { name: "Central CT Building and Remodeling", src: "logos/centralct.webp" },
  { name: "Ibirra Landscaping", src: "logos/ibarra.webp" },
  { name: "Canton Pizza", src: "logos/cantonpizza.webp" },
  { name: "Unionville Autobody", src: "logos/unionville.webp" },
  { name: "Spine Sports", src: "logos/spinesports-logo.webp" },
  { name: "Tonn's Marketplace", src: "logos/tonnsmarketplace.webp" },
  { name: "Valley Stump Grinding", src: "logos/valleystump.webp" },
];

const testimonials = [
    {
      name: "Anthony",
      company: "AJP Landscaping",
      text: "Jeff has been making our apparel for years now and he never disappoints. He's easier to deal with than the larger companies and has the best pricing around.",
    },
    {
      name: "Jordan Tonn",
      company: "Tonn's Marketplace",
      text: "I have worked with Jeff multiple times for custom shirts for my business and he has been amazing to work with. Very responsive and kept me informed throughout the entire process. He met every deadline and we couldn’t be happier with the shirts he made us. Will be doing more business with him in the future.",
    },
    {
      name: "Laura Dutil",
      company: "Farmington High School Lacrosse and Football Booster Clubs",
      text: "I have worked with Jeff, and the Emerald Screen Printing team, on a number of apparel projects for my son's high school sports teams, fundraising shirts and sweatshirts, and team shirts. Jeff's communication and attention to detail was great. I was very pleased with the collaboration in creating the design, the turnaround time, and the end product. Emerald Screen Printing is my go-to company.",
    },
    {
      name: "Costello Landscaping",
      company: "",
      text: "Emerald was recommended to us from another contractor and we've been extremely happy with the t-shirt and sweatshirt quality! Not to mention probably the fastest turn around time we’ve ever had! Emerald is the absolute top of the line and we’re definitely a customer for life!",
    },
    {
      name: "Austin Wosleger",
      company: "Green Earth Solutions LLC",
      text: "I have been using Jeff for several years and he's been a huge help in all aspects of purchasing, putting an order together and even some design help! My orders are 100% correct and zero issues which is a direct correlation to his communication. With his central location in CT, he is someone everyone should know. Thank you always Jeff for your help, quick turnaround time, awesome pricing and being a great guy!!",
    },
    {
      name: "Tyler",
      company: "Anderson Mobile Welding",
      text: "I recently had my business shirts made by Jeff and I can’t be happier with how they came out. Not only are they high quality but also super affordable. Jeff is really awesome to work with and is very professional, I highly recommend using Emerald Screen Printing. I will 100% be using him again!",
    },
    {
      name: "Michael Rosenthal",
      company: "Dynamic Tree",
      text: "Emerald screen printing has always gone above and beyond for us. From employee uniforms to promotional shirts, they have what we need at the right price. When you need uniforms don’t hesitate to reach out to them.",
    },
];
---
<Layout title="Emerald Screen Printing Home | Custom Apparel & Merchandise" description="Emerald Screen Printing creates custom t-shirts, apparel, and promotional products with high-quality printing and embroidery. Serving businesses, schools, and events." canonical="https://emeraldscreenprinting.com">
  <Fragment slot="head">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "LocalBusiness",
          "@id": "https://emeraldscreenprinting.com/#business",
          "name": "Emerald Screen Printing",
          "url": "https://emeraldscreenprinting.com",
          "logo": "https://emeraldscreenprinting.com/logo_color.png",
          "image": [
            "https://emeraldscreenprinting.com/banner/shoppic1.webp",
            "https://emeraldscreenprinting.com/banner/shoppic2.webp",
            "https://emeraldscreenprinting.com/banner/shoppic3.webp"
          ],
          "telephone": "(860) 919-8449",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "1 Deborah Lane",
            "addressLocality": "Farmington",
            "addressRegion": "CT",
            "postalCode": "06032",
            "addressCountry": "US"
          },
          "areaServed": {
            "@type": "AdministrativeArea",
            "name": "Connecticut"
          },
          "description": "Emerald Screen Printing provides custom screen printing, embroidery, and branded apparel for businesses, schools, teams, and events across Connecticut.",
          "sameAs": [
            "https://www.facebook.com/emeraldscreenprintingandembroidery",
            "https://www.instagram.com/emeraldscreenprintingct/"
          ]
        },

        {
          "@type": "Product",
          "@id": "https://emeraldscreenprinting.com/#screen-printing",
          "name": "Custom Screen Printing",
          "description": "High-quality custom screen printing on t-shirts, hoodies, long sleeves, and promotional apparel.",
          "brand": {
            "@type": "Brand",
            "name": "Emerald Screen Printing"
          },
          "image": "https://emeraldscreenprinting.com/customers/dynamictree2.webp",
          "offers": {
            "@type": "Offer",
            "priceCurrency": "USD",
            "price": "8.00",
            "availability": "https://schema.org/InStock",
            "url": "https://emeraldscreenprinting.com/contact"
          }
        },

        {
          "@type": "Product",
          "@id": "https://emeraldscreenprinting.com/#embroidery",
          "name": "Custom Embroidery",
          "description": "Professional embroidery services for uniforms, hats, jackets, and branded apparel.",
          "brand": {
            "@type": "Brand",
            "name": "Emerald Screen Printing"
          },
          "offers": {
            "@type": "Offer",
            "priceCurrency": "USD",
            "availability": "https://schema.org/InStock",
            "url": "https://emeraldscreenprinting.com/contact"
          }
        },

        {
          "@type": "Review",
          "@id": "https://emeraldscreenprinting.com/#review-anthony",
          "author": {
            "@type": "Person",
            "name": "Anthony"
          },
          "reviewBody": "Jeff has been making our apparel for years now and he never disappoints. He's easier to deal with than the larger companies and has the best pricing around.",
          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "5",
            "bestRating": "5"
          },
          "itemReviewed": {
            "@id": "https://emeraldscreenprinting.com/#business"
          }
        },

        {
          "@type": "Review",
          "@id": "https://emeraldscreenprinting.com/#review-jordan",
          "author": {
            "@type": "Person",
            "name": "Jordan Tonn"
          },
          "reviewBody": "Very responsive and kept me informed throughout the entire process. He met every deadline and we couldn’t be happier with the shirts.",
          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "5",
            "bestRating": "5"
          },
          "itemReviewed": {
            "@id": "https://emeraldscreenprinting.com/#business"
          }
        },

        {
          "@type": "ImageObject",
          "@id": "https://emeraldscreenprinting.com/#hero-image",
          "contentUrl": "https://emeraldscreenprinting.com/banner/shoppic1.webp",
          "description": "Inside Emerald Screen Printing shop producing custom apparel",
          "creator": {
            "@type": "Organization",
            "name": "Emerald Screen Printing"
          }
        }
      ]
    }
    </script>
  </Fragment>  
  <main class="space-y-10">

      <!-- Hero / Banner -->
      <div class="sr-only">
        {bannerImages.map((img, idx) => (
          <div>
            {img.group
              ? img.group.map(g => <img src={g.src} alt={g.alt} loading="lazy" decoding="async"/>)
              : <img src={img.src} alt={img.alt} loading="eager" decoding="async" />
            }
            <h1>{slogans[idx]}</h1>
            <p>
              Bold designs. Impeccable detail. Personal touch. Always printed like it's our own.
            </p>
          </div>
        ))}
      </div>
      <HomeBanner client:load images={bannerImages} />

      <!-- Mission + Slogan -->
      <section class="container mx-auto px-4 pb-10 text-center space-y-4">
        <img src="/logo_color.png" alt="Emerald Logo" loading="lazy" decoding="async" class="w-110 mb-4 mt-8 mx-auto animate-fade-in"/>
        <h2 class="text-3xl font-semibold text-emerald-700">Your Local Screen Printing Partner</h2>
        <p class="mb-10 text-lg text-gray-700 max-w-2xl mx-auto">
          We're a small, family-run shop rooted in community and craftsmanship. Every order is treated like it's ours, because to us, it is.
        </p>
        <a href="/contact" class="px-10 py-5 rounded-full bg-emerald-700 text-white font-semibold hover:bg-emerald-600 transition transform hover:scale-105 duration-300 shadow-md hover:shadow-lg">
          Contact Today
        </a>
      </section>

      <!-- Client Logos Grid (SEO-friendly) -->
      <section class="container mx-auto px-4">
        <h3 class="text-2xl text-center font-bold mb-10 text-emerald-700">Trusted By Many Connecticut Brands</h3>
        <!-- client-side marquee for UX -->
        <ClientMarquee client:load clientLogos={clientLogos} />
      </section>

      <section class="container mx-auto px-4 py-12">
        <h2 class="text-3xl font-semibold text-emerald-700 text-center">Custom Apparel for Every Business & Event</h2>
        <p class="text-lg text-gray-700 max-w-3xl mx-auto mt-4 text-center">
          Emerald Screen Printing provides high-quality, affordable custom t-shirts, hoodies, and promotional apparel for businesses, schools, and local events across Connecticut. 
          Our family-owned shop ensures every order receives personal attention and professional finishing, making your brand stand out.
        </p>
        <p class="text-lg text-gray-700 max-w-3xl mx-auto mt-4 text-center">
          From logo design to bulk orders, we make screen printing and embroidery simple and reliable. Your satisfaction and your brand's visibility are our top priorities.
        </p>
      </section>


      <!-- Pricing Block -->
      <section class="flex justify-center p-6">
        <div class="max-w-3xl w-full bg-white shadow-lg rounded-2xl p-4 text-emerald-700 flex flex-col">
          <h2 class="text-xl font-bold mb-4 text-center">Apparel Pricing Starts At:</h2>
          <div class="flex flex-col md:flex-row md:justify-between">
            <ul class="space-y-2 text-sm md:w-1/2">
              <li><span class="font-semibold">Tees:</span> $8+ each</li>
              <li><span class="font-semibold">Long Sleeve Tees:</span> $17 each</li>
              <li><span class="font-semibold">Hoods:</span> $20 each</li>
            </ul>
            <ul class="space-y-2 text-sm md:w-1/2 mt-4 md:mt-0">
              <li><span class="font-semibold">Dri-Fit SS:</span> $12 each</li>
              <li><span class="font-semibold">Dri-Fit LS:</span> $16 each</li>
            </ul>
          </div>
          <p class="mt-4 pt-3 border-t text-sm text-emerald-600 text-center md:text-left">
            <span class="font-semibold">Add-ons:</span> 2X +$2, 3X +$4, 4–6X +$5
          </p>
        </div>
      </section>

      <!-- Apparel Showcase (pre-rendered grid, optional Swiper) -->
      <section class="container mx-auto px-4">
        <h3 class="text-2xl font-bold text-center text-emerald-700 mb-8">Our Work</h3>
        <ApparelShowcase client:load images={showcase} />
      </section>


      <!-- Testimonials -->
      <Testimonials client:load testimonials={testimonials} />
    </main>
</Layout>